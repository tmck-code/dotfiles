#!/bin/bash

# Source AWS credentials for a given profile (legacy — prefer aws-switch instead).
# Usage: source aws-credentials-source [profile-name]

cred_file="$HOME/.aws/credentials"

if ! [ -f "$cred_file" ]; then
  echo "No credentials file at $cred_file"
  return 1 2>/dev/null || exit 1
fi

profile="${1:-}"

if [[ -z "$profile" ]]; then
  echo "Available profiles:"

  command -v ggrep >/dev/null 2>&1 && grep_cmd="ggrep" || grep_cmd="grep"
  $grep_cmd -oP '^\[\K[^\]]+' "$cred_file" | sed 's/^/  /'

  echo ""
  echo "Usage: source aws-credentials-source <profile>"
  return 0 2>/dev/null || exit 0
fi

# Parse the INI section for the given profile
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
in_section=0
while IFS='=' read -r key value; do
  key="$(echo "$key" | tr -d ' \r')"
  value="$(echo "$value" | tr -d ' \r')"
  if [[ "$key" == "[$profile]" ]]; then
    in_section=1
    continue
  elif [[ "$key" == \[* ]]; then
    in_section=0
    continue
  fi
  [[ $in_section -eq 0 ]] && continue
  case "$key" in
  aws_access_key_id) AWS_ACCESS_KEY_ID="$value" ;;
  aws_secret_access_key) AWS_SECRET_ACCESS_KEY="$value" ;;
  aws_session_token) AWS_SESSION_TOKEN="$value" ;;
  esac
done <"$cred_file"

if [[ -z "$AWS_ACCESS_KEY_ID" ]]; then
  echo "✗ profile [$profile] not found"
  return 1 2>/dev/null || exit 1
fi

AWS_DEFAULT_REGION="ap-southeast-2"
export AWS_SESSION_TOKEN AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_DEFAULT_REGION

echo "✓ exported [$profile] credentials"
aws sts get-caller-identity | jq
