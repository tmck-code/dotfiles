#!/usr/bin/env bash

# Update AWS credentials from clipboard, supporting multiple profiles.
# Parses the [profile] header from clipboard content and merges into ~/.aws/credentials.
# Usage: aws-credentials-update [profile-name-override]

if command -v xclip > /dev/null; then
  creds="$(xclip -o 2>/dev/null)"
elif command -v pbpaste > /dev/null; then
  creds="$(pbpaste 2>/dev/null)"
else
  echo "✗ no clipboard utility found"
  exit 1
fi

if [[ $creds != *"aws_access_key_id"*"aws_secret_access_key"*"aws_session_token"* ]]; then
  echo "✗ clipboard does not contain AWS credentials"
  exit 1
fi

# Normalize spacing around =
creds="$(echo "$creds" | sed 's/ *= */=/g')"

# Extract profile name from clipboard or argument
if [[ -n "$1" ]]; then
  profile="$1"
else
  profile=$(echo "$creds" | head -1 | tr -d '\r')
fi

# Extract credential values
key_id="$(echo "$creds" | grep 'aws_access_key_id' | head -1 | cut -d= -f2 | tr -d ' \r')"
secret="$(echo "$creds" | grep 'aws_secret_access_key' | head -1 | cut -d= -f2 | tr -d ' \r')"
token="$(echo "$creds" | grep 'aws_session_token' | head -1 | cut -d= -f2 | tr -d ' \r')"

mkdir -p "$HOME/.aws"
cred_file="$HOME/.aws/credentials"
touch "$cred_file"

# Remove existing profile section if present, then squeeze trailing blank lines.
# awk keeps this portable (macOS/BSD sed -i differs) and treats the [profile]
# header as a literal string rather than a regex.
tmp="$(mktemp)"
awk -v prof="$profile" '
  /^\[/ { skip = ($0 == prof) }
  !skip { print }
' "$cred_file" | sed -e :a -e '/^\n*$/{$d;N;ba' -e '}' > "$tmp"
mv "$tmp" "$cred_file"

# Append new profile
{
  [[ -s "$cred_file" ]] && echo ""
  echo "$profile"
  echo "aws_access_key_id=$key_id"
  echo "aws_secret_access_key=$secret"
  echo "aws_session_token=$token"
} >> "$cred_file"

echo "✓ updated $profile in ~/.aws/credentials"
