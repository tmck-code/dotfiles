#!/bin/bash

set -euo pipefail
[ -n "${DEBUG:-}" ] && set -x

# "good but not great"
# /usr/share/figlet/fonts/Banner3.flf

# Choices
CHOICES="\
/usr/share/figlet/ansi_shadow.flf
/usr/share/figlet/3d-ascii.flf
/usr/share/figlet/3d.flf
/usr/share/figlet/colossal.flf
/usr/share/figlet/cosmike.flf
/usr/share/figlet/cricket.flf
/usr/share/figlet/def_leppard.flf
/usr/share/figlet/fraktur.flf
/usr/share/figlet/s_blood.flf
/usr/share/figlet/smpoison.flf
/usr/share/figlet/swampland.flf
/usr/share/figlet/train.flf"

SECONDS="${1:-10}"
INTERVAL="${2:-3}"

CHOICE="${3:-}"

SEQ=$(seq "$SECONDS" -"$INTERVAL" 0)
[ -z "${CHOICE}" ] && CHOICE=$(echo "$CHOICES" | shuf -n 1 -)

echo "$CHOICE"

# Print all of the countdown frames
for i in $SEQ; do
  clear
  for _ in $(seq 0 $(( $(( $(tput lines) / 2 )) - 5))); do echo ; done
  figlet "$i" -f "$CHOICE" -w "$(tput cols)" -c | lolcat
  sleep "$INTERVAL"
done

