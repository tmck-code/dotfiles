#!/usr/bin/env bash
#
# secrets-load-gpg — decrypt and retrieve secrets from a GPG-encrypted file
#
# Usage:
#   secrets-load-gpg -k <key>                    retrieve a single secret value
#   secrets-load-gpg -k <key> -r <recipient>     specify GPG recipient explicitly
#   secrets-load-gpg --list                       list all available secret keys
#   secrets-load-gpg --clear-cache               clear the decrypted secrets cache
#
# Examples:
#   export $(secrets-load-gpg -k MYSECRET)
#   export $(secrets-load-gpg -k MYSECRET -r my@email.com)
#   secrets-load-gpg --list
#
# The decrypted file is cached at $XDG_RUNTIME_DIR/.secrets-cache-$UID (mode 600)
# for CACHE_TTL seconds (default: 300). The cache is also invalidated if the
# source file ($SECRETS_FILE) is newer than the cache.
# Override the secrets file path with the SECRETS_FILE environment variable.

set +x

SECRETS_FILE="${SECRETS_FILE:-$HOME/.secrets.gpg}"
CACHE_FILE="${XDG_RUNTIME_DIR:-/tmp}/.secrets-cache-${UID}"
CACHE_TTL=300

function _cache_valid() {
  [[ -f "$CACHE_FILE" ]] || return 1
  local age=$(( $(date +%s) - $(stat -c %Y "$CACHE_FILE") ))
  local secrets_mtime cache_mtime
  secrets_mtime=$(stat -c %Y "$SECRETS_FILE")
  cache_mtime=$(stat -c %Y "$CACHE_FILE")
  (( age < CACHE_TTL )) && (( secrets_mtime <= cache_mtime ))
}

function _ensure_cache() {
  _cache_valid && return 0

  local decrypt_args=(--quiet --batch --yes --decrypt)
  [[ -n "${recipient:-}" ]] && decrypt_args+=(--recipient "$recipient")

  local tmpfile
  tmpfile=$(mktemp "${CACHE_FILE}.XXXXXX")
  chmod 600 "$tmpfile"

  if gpg "${decrypt_args[@]}" "$SECRETS_FILE" > "$tmpfile" 2>/dev/null; then
    mv "$tmpfile" "$CACHE_FILE"
    chmod 600 "$CACHE_FILE"
  else
    rm -f "$tmpfile"
    echo "Failed to decrypt secrets file" >&2
    return 1
  fi
}

function list_keys() {
  _ensure_cache || return 1
  grep "^export " "$CACHE_FILE" | sed 's/^export //' | cut -d= -f1
}

function get_key() {
  _ensure_cache || return 1
  grep "^export ${key}=\"" "$CACHE_FILE" | cut -d= -f2- | tr -d '"'
}

function clear_cache() {
  rm -f "$CACHE_FILE"
  echo "Cache cleared." >&2
}

function usage() {
  cat >&2 <<EOF
Usage: $0 [OPTIONS]

Options:
  -k, --key <key>          Secret key to retrieve
  -r, --recipient <id>     GPG recipient (key ID or email); optional if only one secret key exists
  -l, --list               List all available secret keys
      --clear-cache        Clear the decrypted secrets cache
      --cache-ttl <secs>   Override cache TTL in seconds (default: 300)
  -h, --help               Show this help

Examples:
  export \$(secrets-load-gpg -k MYSECRET)
  export \$(secrets-load-gpg -k MYSECRET -r my@email.com)
  secrets-load-gpg --list
EOF
  exit 1
}

key="" recipient="" cmd="get"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -k|--key)        key="$2";       shift 2 ;;
    -r|--recipient)  recipient="$2"; shift 2 ;;
    -l|--list)       cmd="list";     shift ;;
    --clear-cache)   cmd="clear";    shift ;;
    --cache-ttl)     CACHE_TTL="$2"; shift 2 ;;
    -h|--help)       usage ;;
    *)               usage ;;
  esac
done

case "$cmd" in
  list)
    list_keys
    ;;
  clear)
    clear_cache
    ;;
  get)
    if [[ -z "$key" ]]; then
      echo "Error: --key is required" >&2
      usage
    fi
    if [ -t 1 ]; then
      echo -e "\e[3;41m !! Warning! do NOT print the result of this script to STDOUT !! \e[0m\n" >&2
      usage
    fi
    echo "$key=$(get_key)"
    ;;
esac
